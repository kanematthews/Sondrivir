  m_Script: {fileID: 11500000, guid: 4e873c746a6c0b04cb6d831a2d06da0c, type: 3}
  m_Name: Ellen
  m_EditorClassIdentifier: Assembly-CSharp::NPCDialogueData
  npcName: Ellen
  greeting: Oh, someone new! Be careful of the area!
  dialogueChoices:
  - playerText: Where am I?
    npcResponse: You're a few miles from Arcanum... Where did you come from?
    closesDialogue: 0
    goBackAfterResponse: 0
  - playerText: Who are you?
    npcResponse: 'My name is Ellen! I''m a scout around here keeping an eye out for
      the nearby town of Treason. '
    closesDialogue: 0
    goBackAfterResponse: 0
  - playerText: What do you mean by be careful?
    npcResponse: Well... This place is littered with strange creatures as of the
      recent "arcane surges"...
    closesDialogue: 0
    goBackAfterResponse: 0
